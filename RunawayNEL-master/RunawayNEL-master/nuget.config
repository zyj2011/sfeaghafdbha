<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- 清除默认源 -->
    <clear />
    <!-- 腾讯云 NuGet 镜像（推荐，国内最快） -->
    <add key="nuget-tencent" value="https://mirrors.tencent.com/nuget/nuget-org/" />
    <!-- 阿里云 NuGet 镜像（备用） -->
    <add key="nuget-aliyun" value="https://mirrors.aliyun.com/nuget/packages" />
    <!-- 官方 NuGet 源（备用） -->
    <add key="nuget-org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <activePackageSource>
    <add key="nuget-tencent" value="https://mirrors.tencent.com/nuget/nuget-org/" />
  </activePackageSource>
</configuration>
